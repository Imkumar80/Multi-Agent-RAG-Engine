# Project-wide gitignore
# This file contains common patterns for the entire Resonav project

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.worktrees/

# Temporary files
*.tmp
*.temp
.cache/
tmp/

# Environment files
# .env
# .env.local
# .env.development.local
# .env.test.local
# .env.production.local

# Build outputs (if any)
build/
dist/

# Log files
*.log
logs/

# Coverage reports
coverage/
.nyc_output/

# Dependency directories (for safety)
node_modules/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
ENV/
env.bak/
venv.bak/

# Jupyter Notebook checkpoints
.ipynb_checkpoints

# Database files
*.db
*.sqlite
*.sqlite3

# Documentation build outputs
docs/_build/
*.pdf
!ml-backend/Docs/*.pdf

# Backup files
*.bak
*.backup
